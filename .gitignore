# Dependencies
node_modules/

# Build outputs
dist/
.next/
.turbo/

# Database
*.db
*.db-journal
*.db-wal

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
*.swp
*.swo

# Claude Code
.claude/

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Test
coverage/
test-results/
playwright-report/

# Logs
*.log

# Runtime data
apps/backend/photos/
apps/backend/photos
apps/backend/data/

# 人脸识别 ONNX 模型权重（~16MB）：通过 pnpm models:download 下载，不入版本
apps/backend/assets/models/*.onnx
# 仓库根的 photos/ 是测试以错误 cwd 跑时把合成产物泄漏到这里的目录，不入版本
/photos/

# Autopilot ephemeral state (sessions/requirements 是按对话生成的临时工作目录，不入版本)
# 不带末尾 / —— 这样在 worktree 里它们是 symlink (非目录) 时也能匹配
.autopilot/sessions
.autopilot/requirements

# Autopilot 合并冲突时遗留的备份目录
.autopilot-conflict-*/

# Worktree 本地配置
local-config.json

# pnpm debug logs
pnpm-debug.log*

# autopilot 运行时会话态（临时，不入库）
.autopilot/runtime/
