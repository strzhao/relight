# 后端端口
PORT=3000

# Web 常驻端口（避开 3000-3499 dev / 4001-5499 worktree 区；Mac App「打开 Web」
# 通过 /api/runtime/config.webPort 读取此值，无需在客户端再配置）
WEB_PORT=3601

# 数据库路径 (SQLite)
DATABASE_PATH=./data/relight.db

# Redis 连接 (BullMQ 任务队列)
REDIS_URL=redis://localhost:6379

# 照片存储根目录
STORAGE_ROOT=./photos

# AI 服务配置 (OpenAI 兼容 API)
AI_BASE_URL=http://127.0.0.1:8001/v1
AI_API_KEY=qwen-local-key
AI_MODEL=qwen3.6-35b
AI_VISION_MODEL=qwen3.6-35b

# 视频 AI 分析支持
# VIDEO_ENABLED=true              # 设为 false 禁用视频分析（默认开启）
# VIDEO_FRAME_COUNT=6             # 每段视频抽帧数量（3×2 雪碧图）
# FFMPEG_PATH=ffmpeg              # ffmpeg 可执行路径（默认 PATH 查找）
# FFPROBE_PATH=ffprobe            # ffprobe 可执行路径（默认 PATH 查找）

# Whisper 语音转录（可选，缺失时视频仍做视觉分析，transcript 为 NULL）
# WHISPER_ENABLED=true
# WHISPER_PYTHON=/path/to/whisper-venv/bin/python3   # 指向你的 whisper venv（项目内置默认指向 martin/transcribe.py）
# WHISPER_SCRIPT=/path/to/transcribe.py              # 兼容 OpenAI Whisper / mlx-whisper / faster-whisper 三引擎的 CLI
# WHISPER_ENGINE=mlx              # mlx / openai-whisper / faster
# WHISPER_MODEL=large-v3-turbo
# WHISPER_LANGUAGE=auto           # zh / en / auto

# 人脸识别（ONNX Runtime + SCRFD + ArcFace；模型权重通过 pnpm models:download 拉取）
# FACE_RECOGNITION_THRESHOLD=5     # 人物头像在 /photos 顶部展示的最低 memberCount 阈值
# FACE_CLUSTERING_THRESHOLD=0.5    # cosine 归并阈值（>= 视为同一人）
# FACE_DETECTION_THRESHOLD=0.5     # SCRFD 检测分数阈值
# FACE_MIN_SIZE=80                 # 最小人脸 bbox 边长（像素）
# MODELS_DIR=./apps/backend/assets/models   # 模型目录（多 worktree 可共享主仓库一份）
# MODELS_MIRROR=hf-mirror.com      # HuggingFace 镜像（中国用户加速）
