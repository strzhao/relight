{
  "name": "relight",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:lighthouse": "lhci autorun",
    "test:size": "size-limit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm exec turbo build --filter='!@relight/mac'",
    "db:push": "pnpm --filter @relight/backend db:push",
    "db:studio": "pnpm --filter @relight/backend db:studio",
    "prepare": "husky",
    "postinstall": "node scripts/sync-worktree-env.mjs",
    "worktree:setup": "node scripts/sync-worktree-env.mjs",
    "workers:start": "pm2 start ecosystem.config.cjs",
    "workers:stop": "pm2 stop relight-workers",
    "workers:reload": "pm2 reload relight-workers",
    "workers:logs": "pm2 logs relight-workers --lines 100",
    "workers:status": "pm2 status"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@lhci/cli": "^0.15.1",
    "@size-limit/preset-app": "^11.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "pm2": "^7.0.1",
    "size-limit": "^11.2.0",
    "turbo": "^2.5.0",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "sharp"
    ]
  }
}
